{
  "name": "kraken-overnight-guard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Chrome extension that monitors Kraken Prop LONG positions overnight and can close them under strict, opt-in safety gates.",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
