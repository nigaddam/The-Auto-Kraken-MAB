# Copy to .env and fill in. Never commit the real .env file.

# --- Kraken Prop execution target (Stage 2+) ---
# Your Prop account identifier. Never hardcode this in source.
KRAKEN_PROP_ACCOUNT_ID=
# Base URL pattern for your Prop account. Symbol/route is appended by config per-asset.
KRAKEN_PROP_BASE_URL=https://pro.kraken.com/prop/account

# --- Dedicated persistent Chrome profile (Stage 2+) ---
# Absolute path to a Chrome user-data-dir used ONLY for this tool.
# Create with: python scripts/launch_chrome_profile.py --setup
CHROME_USER_DATA_DIR=
# Profile directory name inside CHROME_USER_DATA_DIR (e.g. "Default" or "Profile 1").
CHROME_PROFILE_DIRECTORY=Default

# --- Notifications ---
# Telegram is optional and off by default (see config.yaml notifications.telegram).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Safety ---
# Global kill switch override. Leave unset/false. Prefer `kraken-guard kill`.
KRAKEN_GUARD_KILLED=false
